logs/
*.log
npm-debug.log*

# ─── OS metadata ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Editor metadata ────────────────────────────────────────────────────────
.vscode/settings.json
.idea/

# ─── Internal tooling (assessment workspace) ────────────────────────────────
merge/