# =============================================================================
#  JF Property Management CRM — Backend Environment Configuration
#  Copy this file to `.env` and fill in the values for your local environment.
#  NEVER commit `.env` to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------

# PORT — The HTTP port on which the Express server will listen.
# Default: 5000
PORT=5000

# NODE_ENV — Application runtime environment.
# Accepted values: development | production
# Controls: Prisma query logging, error verbosity, and runtime behaviour.
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------

# DATABASE_URL — PostgreSQL connection string used exclusively by Prisma.
# Format:  postgresql://<user>:<password>@<host>:<port>/<database>?schema=public
# Example: postgresql://postgres:secretpassword@localhost:5432/jf_property_crm?schema=public
#
# Security notes:
#   - Use a strong, unique password in production.
#   - Restrict the database user to the minimum required privileges.
#   - Never expose this value in logs, API responses, or version control.
DATABASE_URL="postgresql://username:password@localhost:5432/jf_property_crm?schema=public"
